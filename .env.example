# RimWorld local development environment
# Copy this file to .env and fill in the values for your machine.
# .env is gitignored — never commit it.

# Base path to your RimWorld install directory.
# Mods/, ModsConfig.xml, and RimWorldWin64.exe are all inferred from this.
RIMWORLD_DIR=E:\SteamLibrary\steamapps\common\RimWorld

# Full path to Player.log — written fresh each RimWorld session.
# This lives in AppData, not the game directory.
# Windows: C:\Users\YourName\AppData\LocalLow\Ludeon Studios\RimWorld by Ludeon Studios\Player.log
# Mac:     ~/Library/Logs/Unity/Player.log
RIMWORLD_LOG_FILE=C:\Users\YourName\AppData\LocalLow\Ludeon Studios\RimWorld by Ludeon Studios\Player.log
